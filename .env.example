# ============================================
# GeoMhls — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# DO NOT commit .env to version control.

# --- Server ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/geomhls?retryWrites=true&w=majority
JWT_SECRET=replace-with-random-64-character-string-for-production
JWT_REFRESH_SECRET=replace-with-another-random-64-character-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
CLIENT_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# --- Client (Vite prefix: VITE_) ---
# Create client/.env with these:
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
