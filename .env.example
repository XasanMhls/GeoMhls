# ============================================
# GeoMhls — Environment Variables
# ============================================
# LOCAL DEV: copy to server/.env and client/.env
# RAILWAY:   set these in Railway → Variables tab

# --- Server env vars ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/geomhls?retryWrites=true&w=majority
JWT_SECRET=replace-with-random-64-character-string-for-production
JWT_REFRESH_SECRET=replace-with-another-random-64-character-string
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# CLIENT_URL = your Railway public domain, e.g. https://geomhls.up.railway.app
CLIENT_URL=https://your-app.up.railway.app
NODE_ENV=production
# PORT is set automatically by Railway — do not hardcode

# --- Client env vars (baked in at build time by Vite) ---
# Set these in Railway Variables so they are available during `npm run build`
VITE_API_URL=/api
# Leave VITE_SOCKET_URL empty — socket will auto-connect to the same origin
VITE_SOCKET_URL=
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token
